{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python Debugger: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal"
    },
    {
      "name": "Eval GoEmotions: Quick smoke",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/tests/evaluation/eval_goemotions.py",
      "console": "integratedTerminal",
      "args": [
        "--n-samples",
        "10",
        "--no-baselines"
      ],
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "justMyCode": false
    },
    {
      "name": "Eval GoEmotions: Full run",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/tests/evaluation/eval_goemotions.py",
      "console": "integratedTerminal",
      "args": [
        "--full",
        "--llm-provider",
        "openai",
        "--cache-dir",
        "cache",
        "--output-dir",
        "outputs/goemotions_experiments",
        "--train-on-all"
      ],
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "justMyCode": false
    },
    {
      "name": "10kGNAD: Run eval_10kGNAD",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/tests/eval_10kGNAD.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "DATA_DIR": "${workspaceFolder}/Dataset_Descriptives/data/10kGNAD",
        "OUTPUT_DIR": "${workspaceFolder}/outputs/10kgnad_fusion",
        "CACHE_DIR": "${workspaceFolder}/cache/10kGNAD"
      },
      "justMyCode": false
    },
    {
      "name": "Run eval_goemotions.py (No Debug)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/tests/evaluation/eval_goemotions.py",
      "console": "integratedTerminal",
      "args": [
        "--n-samples",
        "20"
      ],
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "justMyCode": false
    },
    {
      "name": "Debug eval_goemotions.py",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/tests/evaluation/eval_goemotions.py",
      "console": "integratedTerminal",
      "args": [
        "--n-samples",
        "20"
      ],
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "justMyCode": false
    },
    {
      "name": "Run eval_goemotions.py (With Inputs)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/tests/evaluation/eval_goemotions.py",
      "console": "integratedTerminal",
      "args": [
        "--n-samples",
        "${input:nSamples}",
        "--llm-provider",
        "${input:llmProvider}",
        "--cache-dir",
        "${input:cacheDir}"
      ],
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "justMyCode": false
    }
  ],
  "inputs": [
    {
      "id": "nSamples",
      "type": "promptString",
      "description": "Number of samples for train/val/test (or leave blank to use percentages)",
      "default": "20"
    },
    {
      "id": "llmProvider",
      "type": "pickString",
      "description": "LLM provider",
      "options": [
        "openai",
        "deepseek"
      ],
      "default": "openai"
    },
    {
      "id": "cacheDir",
      "type": "promptString",
      "description": "Cache directory",
      "default": "cache"
    }
  ]
}